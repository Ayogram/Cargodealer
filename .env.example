# MongoDB Connection String (Required)
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/cargodealer
MONGO_URI=mongodb://localhost:27017/cargodealer

# JWT Secret for session security
JWT_SECRET=cargodealer_secure_secret_2026

# Email Configuration (for Verification & Admin OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
